---
import { EDUCATION } from '../data/portfolio';
const { degree, certs } = EDUCATION;
---

<section id="educacion" data-screen-label="04 Educación">
  <header class="sec-head">
    <div>
      <div class="sec-tag"><b>04</b>/ educacion.md</div>
      <h2 class="sec-title">Educación & certs<em>.</em></h2>
    </div>
    <div class="sec-meta">UPC · IBM · MS · UTEC · Cibertec</div>
  </header>

  <!-- degree -->
  <div style="border:1px solid var(--line);background:#0c0c0c;padding:28px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start" class="degree">
    <div>
      <div style="font-size:11px;color:var(--dim);letter-spacing:.15em;text-transform:uppercase">grado universitario</div>
      <h3 style="margin:10px 0 6px;font-size:clamp(20px,2.2vw,26px);font-weight:500;letter-spacing:-.01em">{degree.title}</h3>
      <div style="color:#cfcfcf;font-size:14px">{degree.school}</div>
      <div style="color:var(--dim);font-size:12px;margin-top:6px">{degree.note}</div>
    </div>
    <div style="text-align:right" class="degree-meta">
      <div style="color:var(--accent);font-size:clamp(28px,3.5vw,44px);font-weight:500;letter-spacing:-.02em;line-height:1">{degree.range}</div>
      <div style="color:var(--dim);font-size:12px;margin-top:10px">5 años · 200+ créditos</div>
    </div>
  </div>

  <!-- certs -->
  <div style="margin-top:32px">
    <div style="font-size:11px;color:var(--dim);letter-spacing:.15em;text-transform:uppercase;margin-bottom:14px">
      $ ls ./certifications
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line)" class="certsgrid">
      {certs.map((c, i) => (
        <div style={`padding:22px 20px;${(i + 1) % 4 !== 0 ? 'border-right:1px solid var(--line);' : ''}background:#0c0c0c;min-height:180px;display:flex;flex-direction:column`}>
          <div style="display:flex;justify-content:space-between;align-items:baseline">
            <div style="font-size:13px;color:var(--accent);font-weight:500">{c.issuer}</div>
            <div style="font-size:11px;color:var(--dim)">{c.year}</div>
          </div>
          <div style="margin-top:14px;color:var(--fg);font-size:14px;line-height:1.45">{c.title}</div>
          <div style="margin-top:auto;padding-top:16px;color:var(--dim);font-size:11px">
            <span style="color:var(--accent)">#</span> {c.code}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
