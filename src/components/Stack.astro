---
import { STACK } from '../data/portfolio';
---

<section id="stack" data-screen-label="06 Stack">
  <header class="sec-head">
    <div>
      <div class="sec-tag"><b>06</b>/ stack.md</div>
      <h2 class="sec-title">Stack tecnológico<em>.</em></h2>
    </div>
    <div class="sec-meta">6 categorías · 40+ herramientas</div>
  </header>

  <div style="display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line)" class="stackgrid">
    {STACK.map((g, i) => (
      <div style={`padding:28px 24px;${(i + 1) % 3 !== 0 ? 'border-right:1px solid var(--line);' : ''}${i < STACK.length - 3 ? 'border-bottom:1px solid var(--line);' : ''}background:#0c0c0c`}>
        <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:16px">
          <span style="color:var(--accent);font-size:11px">/{g.no}</span>
          <h3 style="margin:0;font-size:16px;font-weight:500;letter-spacing:-.005em">{g.label}</h3>
          <span style="margin-left:auto;font-size:11px;color:var(--dim)">{g.items.length}</span>
        </div>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:2px">
          {g.items.map((it) => (
            <li style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px dashed var(--line);font-size:13px;color:#cfcfcf">
              <span>{it}</span>
              <span style="color:var(--dim)">●</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
