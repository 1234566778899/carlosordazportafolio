---
import { PROFILE } from '../data/portfolio';

const links = [
  { k: 'email',    v: PROFILE.email,    href: `mailto:${PROFILE.email}` },
  { k: 'phone',    v: PROFILE.phone,    href: `tel:${PROFILE.phone.replace(/\s/g, '')}` },
  { k: 'linkedin', v: PROFILE.linkedin, href: `https://${PROFILE.linkedin}` },
  { k: 'github',   v: PROFILE.github,   href: `https://${PROFILE.github}` },
  { k: 'site',     v: PROFILE.site,     href: `https://${PROFILE.site}` },
];
---

<section id="contacto" data-screen-label="07 Contacto">
  <header class="sec-head">
    <div>
      <div class="sec-tag"><b>07</b>/ contacto.md</div>
      <h2 class="sec-title">Hablemos<em>.</em></h2>
    </div>
    <div class="sec-meta">abierto a freelance & full-time</div>
  </header>

  <div style="display:grid;grid-template-columns:minmax(0,1.2fr) minmax(0,1fr);gap:64px" class="contactgrid">
    <div>
      <p style="margin:0;font-size:clamp(20px,2.4vw,32px);line-height:1.4;color:var(--fg);max-width:20ch;font-weight:400">
        ¿Tienes una idea? <span class="hl">cuéntame.</span><br/>
        Respondo en menos de 24h hábiles.
      </p>
      <a href={`mailto:${PROFILE.email}`} style="display:inline-flex;align-items:center;gap:10px;margin-top:28px;padding:16px 22px;border:1px solid var(--accent);color:#0a0a0a;background:var(--accent);font-size:13px;font-weight:500">
        <span>{PROFILE.email}</span>
        <span>→</span>
      </a>
      <div style="margin-top:32px;font-size:12px;color:var(--dim)">
        <span class="hl">$</span> echo "Lima, Perú · GMT-5 · ES/EN"
      </div>
    </div>

    <ul style="margin:0;padding:0;list-style:none;border-top:1px solid var(--line)">
      {links.map((l) => (
        <li>
          <a href={l.href}
             target={l.k !== 'email' && l.k !== 'phone' ? '_blank' : undefined}
             rel={l.k !== 'email' && l.k !== 'phone' ? 'noopener noreferrer' : undefined}
             class="contact-link"
             style="display:grid;grid-template-columns:100px 1fr 24px;gap:12px;padding:18px 0;border-bottom:1px solid var(--line);align-items:center;color:var(--fg);font-size:14px">
            <span style="color:var(--dim);font-size:11px;letter-spacing:.15em;text-transform:uppercase">{l.k}</span>
            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{l.v}</span>
            <span style="text-align:right">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .contact-link { transition: color .15s; }
  .contact-link:hover { color: var(--accent) !important; }
</style>
