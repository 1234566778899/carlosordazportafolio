---
import { TIMELINE } from '../data/portfolio';
---

<section id="trayectoria" data-screen-label="03 Trayectoria">
  <header class="sec-head">
    <div>
      <div class="sec-tag"><b>03</b>/ trayectoria.md</div>
      <h2 class="sec-title">Trayectoria<em>.</em></h2>
    </div>
    <div class="sec-meta">3 empresas<br/>2021 — presente</div>
  </header>

  <ol style="list-style:none;margin:0;padding:0;border-top:1px solid var(--line)">
    {TIMELINE.map((j) => (
      <li style="display:grid;grid-template-columns:120px 1fr 220px;gap:32px;padding:28px 0;border-bottom:1px solid var(--line);align-items:start" class="jobrow">
        <div style="color:var(--dim);font-size:12px;line-height:1.8">
          <div style={j.current ? 'color:var(--accent)' : 'color:var(--fg)'}>{j.range}</div>
          <div>{j.place}</div>
          {j.current && (
            <div style="margin-top:6px;display:inline-flex;align-items:center;gap:6px;color:var(--accent)">
              <span class="dot" /> current
            </div>
          )}
        </div>
        <div>
          <div style="font-size:11px;color:var(--dim);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px">{j.role}</div>
          <h3 style="margin:0 0 14px;font-size:clamp(20px,2.2vw,28px);font-weight:500;letter-spacing:-.01em">{j.co}</h3>
          <ul style="margin:0;padding:0;list-style:none;color:#cfcfcf;font-size:13px;line-height:1.7">
            {j.bullets.map((b) => (
              <li style="display:flex;gap:10px;padding-top:4px">
                <span style="color:var(--accent);flex-shrink:0">›</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-end" class="jobtags">
          {j.tags.map((t) => (
            <span style="font-size:11px;color:var(--dim);border:1px solid var(--line-hi);padding:3px 8px">{t}</span>
          ))}
        </div>
      </li>
    ))}
  </ol>
</section>
